<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="app.cridergpt.android">

    <application
        android:name="app.cridergpt.android.CriderGPTApplication"
        android:allowBackup="true"
        android:label="CriderGPT"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true">

        <activity android:name="app.cridergpt.android.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name="app.cridergpt.android.ui.auth.SignInActivity" />
        <activity android:name="app.cridergpt.android.ui.PaymentActivity" />

    </application>

</manifest>
